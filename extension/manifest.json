{
  "manifest_version": 3,
  "name": "Commonplace Pinboard",
  "description": "Capture saved page snapshots and reopen them from any tab.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Commonplace Pinboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "scripting", "tabs"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
